GROQ_API_KEY=replace-with-your-groq-key
APP_SECRET_KEY=replace-with-a-long-random-secret
OWNER_SESSION_TTL_MINUTES=1440
DEFAULT_BUSINESS_SLUG=sahel

# Zero-budget email notifications via free SMTP (Gmail, Outlook, etc.)
# Gmail: create an app password at https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# NOTIFICATION_EMAIL=owner-email@gmail.com  # defaults to business owner_email

# Local professional default: one SQLite database file.
DATABASE_URL=sqlite:///./sahel.db
AUTO_CREATE_TABLES=true

# Hosted PostgreSQL example for Supabase/Neon/Aiven/etc.
# Direct (IPv6): postgresql+psycopg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Pooler (IPv4, recommended on Windows): postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
# For hosted production databases, set AUTO_CREATE_TABLES=false and run:
# alembic upgrade head

# Google OAuth Client ID for Sign-In
# Create at https://console.cloud.google.com → APIs & Services → Credentials → OAuth client ID
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Frontend URL (used in verification emails)
# SITE_URL=https://sahel.ai

# Frontend deployment variable:
# VITE_API_URL=https://your-koyeb-api.example.com
