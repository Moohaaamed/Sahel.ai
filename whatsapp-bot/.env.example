# URL de l'API backend Sahel.ai
API_BASE=https://TON_USER-sahel-api.hf.space

# Slug du commerce par défaut (optionnel, défaut: sahel)
DEFAULT_BUSINESS_SLUG=sahel

# Niveau de log (error, warn, info, debug - défaut: silent)
LOG_LEVEL=info

# Token du bot Telegram (optionnel, pour le bot Telegram)
# Obtenez-le via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=
